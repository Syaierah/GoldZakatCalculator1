<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme menggunakan Material3 supaya MaterialCardView berfungsi -->
    <style name="Theme.GoldZakatCalculator2" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/pink_primary</item>
        <item name="colorPrimaryDark">@color/pink_dark</item>
        <item name="colorAccent">@color/pink_primary</item>

        <!-- Penting: Tukar ke 'true' supaya ikon jam/bateri gelap -->
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/pink_soft</item>

        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Theme for activities that use a Toolbar in their layout -->
    <style name="Theme.GoldZakatCalculator2.NoActionBar" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/pink_primary</item>
        <item name="colorPrimaryDark">@color/pink_dark</item>
        <item name="colorAccent">@color/pink_primary</item>

        <!-- Lakukan yang sama untuk NoActionBar -->
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/pink_soft</item>

        <item name="android:fontFamily">sans-serif</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

</resources>